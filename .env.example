DB_SERVER=your-mysql-host;port=3306
DB_SERVER_USERNAME=your-mysql-user
DB_SERVER_PASSWORD=your-mysql-password
DB_DATABASE=your-mysql-database

# Common hosted MySQL aliases are also supported:
# MYSQL_HOST=your-mysql-host
# MYSQL_PORT=3306
# MYSQL_USER=your-mysql-user
# MYSQL_PASSWORD=your-mysql-password
# MYSQL_DATABASE=your-mysql-database

# Or use a MySQL-compatible URL instead of the four DB_* values:
# MYSQL_URL=mysql://user:password@host:3306/database
